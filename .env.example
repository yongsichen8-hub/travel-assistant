# LLM (OpenAI 兼容格式)
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=sk-xxxxx
LLM_MODEL=deepseek-v4-flash

# 高德地图 (服务端 Web服务 API)
AMAP_API_KEY=your-amap-server-key

# 高德地图 JS API (前端浏览器使用)
NEXT_PUBLIC_AMAP_KEY=your-frontend-amap-key
NEXT_PUBLIC_AMAP_SECURITY_CODE=your-security-code

# 航班 API 数据源（corporate / variflight）
FLIGHT_DATA_SOURCE=variflight

# 飞常准 VariFlight（主数据源 - 航班时刻表）
VARIFLIGHT_API_KEY=sk-your-api-key-here

# 和风天气 API
QWEATHER_API_KEY=your-qweather-key
QWEATHER_API_HOST=your-host.re.qweatherapi.com

# 可选
MAX_AGENT_ITERATIONS=8
LLM_TEMPERATURE=0.7

# 飞书 OAuth（部署时需改为实际服务器地址）
FEISHU_APP_ID=your-feishu-app-id
FEISHU_APP_SECRET=your-feishu-app-secret
FEISHU_REDIRECT_URI=http://your-server-ip:9527/api/feishu/callback

# Token 加密密钥（64 字符 hex，可用 openssl rand -hex 32 生成）
TOKEN_ENCRYPTION_KEY=your-64-char-hex-key
